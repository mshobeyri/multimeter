type: api
title: Post echo with inputs
description: Send dynamic values via inputs and extract them from the echoed response
inputs:
  username: alice
  role: admin
outputs:
  echoed_username: body[body][username]
  echoed_role: body[body][role]
  method: body[method]
url: https://test.mmt.dev/echo
method: post
format: json
body:
  username: i:username
  role: i:role
