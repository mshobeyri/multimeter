type: env
variables:
  api_url: "https://test.mmt.dev"

certificates:
  # CA certificates — add your Certificate Authority PEM files here
  ca:
    paths:
      - "./certs/ca.crt"

  # Client certificates for mTLS — matched by host pattern
  clients:
    - name: "Example API"
      host: "*.example.com"
      cert_path: "./certs/client.crt"
      key_path: "./certs/client.key"
      passphrase_env: "CLIENT_CERT_PASS"
