{
  "name": "multimeter",
  "publisher": "mshobeyri",
  "displayName": "Multimeter",
  "description": "API test tools",
  "version": "1.16.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/mshobeyri/multimeter.git"
  },
  "icon": "res/logo.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Testing", "Programming Languages", "AI"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:mmt",
    "onChatParticipant:multimeter",
    "onChatParticipant:mmt"
  ],
  "main": "./dist/extension.js",
  "enabledApiProposals": [
    "chatProvider"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mmt",
        "extensions": [
          ".mmt"
        ],
        "aliases": [
          "MMT",
          "Multimeter Test"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "res/logo_file.svg",
          "dark": "res/logo_file.svg"
        }
      }
    ],
    "chatParticipants": [
      {
        "id": "multimeter",
        "name": "Multimeter",
        "fullName": "Multimeter Assistant",
        "description": "What kind of test do you want today?",
        "isSticky": true,
        "commands": [
          {
            "name": "run",
            "description": "Run a test or api @mmt /run <test path or api .mmt file path>"
          },
          {
            "name": "print-js",
            "description": "Print the generated JS code from a test @mmt /print-js <test path>"
          },
          {
            "name": "doc",
            "description": "Generate documentation from an API @mmt /doc <api .mmt file path>"
          },
          {
            "name": "help",
            "description": "Show help information about using Multimeter @mmt /help"
          }
        ]
      },
      {
        "id": "mmt",
        "name": "mmt",
        "fullName": "Multimeter Assistant",
        "description": "What kind of test do you want today?",
        "isSticky": false,
        "commands": [
          {
            "name": "run",
            "description": "Run a test or api @mmt /run <test path or api .mmt file path>"
          },
          {
            "name": "print-js",
            "description": "Print the generated JS code from a test @mmt /print-js <test path>"
          },
          {
            "name": "doc",
            "description": "Generate documentation from an API @mmt /doc <api .mmt file path>"
          },
          {
            "name": "help",
            "description": "Show help information about using Multimeter @mmt /help"
          }
        ]
      }
    ],
    "grammars": [
      {
        "language": "mmt",
        "scopeName": "source.mmt",
        "path": "./syntaxes/mmt.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Multimeter",
      "properties": {
        "multimeter.network.timeout": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout in milliseconds",
          "minimum": 1000,
          "maximum": 300000
        },
        "multimeter.body.auto.format": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format the body of the responses"
        },
        "multimeter.editor.fontSize": {
          "type": "number",
          "default": 12,
          "description": "Font size for the MMT YAML editor",
          "minimum": 8,
          "maximum": 40
        },
        "multimeter.editor.defaultPanel": {
          "type": "string",
          "default": "yaml-ui",
          "enum": ["yaml-ui", "yaml", "ui"],
          "enumDescriptions": [
            "Show both YAML editor and UI panel (split view)",
            "Show only the YAML editor",
            "Show only the UI panel"
          ],
          "description": "Default panel layout when opening MMT files"
        },
        "multimeter.editor.collapseDescription": {
          "type": "boolean",
          "default": false,
          "description": "Automatically collapse multi-line description fields when opening MMT files"
        },
        "multimeter.workspaceEnvFile": {
          "type": "string",
          "default": "multimeter.mmt",
          "description": "Path to the workspace environment file (type: env) relative to the workspace root. This file is loaded on workspace open and sets environment variables, presets, and certificates."
        },
        "multimeter.showLogOnRun": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the Multimeter log panel when running a test, API, or suite from the editor"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "mmt.editor",
        "displayName": "MMT Editor",
        "selector": [
          {
            "filenamePattern": "file:/**/*.mmt"
          }
        ],
        "icon": {
          "light": "res/activity.png",
          "dark": "res/activity.png"
        }
      }
    ],
    "commands": [
      {
        "command": "multimeter.mmt.show",
        "title": "Show MMT Preview",
        "category": "Preview",
        "icon": {
          "light": "res/activity.png",
          "dark": "res/activity.png"
        }
      },
      {
        "command": "multimeter.mmt.show.yaml",
        "title": "Hide UI Preview",
        "icon": "$(layout-sidebar-right-dock)"
      },
      {
        "command": "multimeter.mmt.show.ui",
        "title": "Hide YAML Preview",
        "icon": "$(layout-sidebar-left-dock)"
      },
      {
        "command": "multimeter.mmt.show.full",
        "title": "Show Full Preview",
        "icon": "$(layout-centered)"
      },
      {
        "command": "multimeter.mmt.show.as.text",
        "title": "Open as MMT Text Editor",
        "category": "MMT",
        "icon": "$(code-oss)"
      },
      {
        "command": "multimeter.history.clear",
        "title": "Clear History",
        "icon": "$(clear-all)"
      },
      {
        "command": "multimeter.setting.open",
        "title": "Open Multimeter Settings",
        "category": "Multimeter"
      },
      {
        "command": "multimeter.environment.focus",
        "title": "Focus Environment Variables",
        "category": "Multimeter"
      },
      {
        "command": "multimeter.environment.clear",
        "title": "Clear Environment Variables",
        "icon": "$(clear-all)"
      },
      {
        "command": "multimeter.environment.refresh",
        "title": "Refresh Environment Variables",
        "icon": "$(refresh)"
      },
      {
        "command": "multimeter.environment.loadFromFile",
        "title": "Load Environment from Workspace File",
        "category": "Multimeter",
        "icon": "$(cloud-download)"
      },
      {
        "command": "multimeter.connections.refresh",
        "title": "Refresh Connections",
        "icon": "$(refresh)"
      },
      {
        "command": "multimeter.connections.closeAll",
        "title": "Close All Connections",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multimeter-activitybar",
          "title": "Multimeter",
          "icon": "res/activity.png"
        }
      ],
      "panel": [
        {
          "id": "multimeter-panel",
          "title": "Multimeter",
          "icon": "res/activity.png"
        }
      ]
    },
    "views": {
      "multimeter-activitybar": [
        {
          "id": "multimeter.convertor",
          "name": "Convertor",
          "icon": "res/activity.png",
          "type": "webview"
        },
        {
          "id": "multimeter.mock.server",
          "name": "Mock Server",
          "icon": "res/activity.png",
          "type": "webview"
        },
        {
          "id": "multimeter.connections",
          "name": "Connections",
          "icon": "res/activity.png",
          "type": "webview"
        }
      ],
      "multimeter-panel": [
        {
          "id": "multimeter.environment",
          "name": "Environment Variables",
          "icon": "res/activity.png",
          "type": "webview"
        },
        {
          "id": "multimeter.history",
          "name": "History",
          "icon": "res/activity.png",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "multimeter.history.clear",
          "when": "view == multimeter.history",
          "group": "navigation"
        },
        {
          "command": "multimeter.environment.refresh",
          "when": "view == multimeter.environment",
          "group": "navigation"
        },
        {
          "command": "multimeter.environment.clear",
          "when": "view == multimeter.environment",
          "group": "navigation"
        },
        {
          "command": "multimeter.connections.refresh",
          "when": "view == multimeter.connections",
          "group": "navigation"
        },
        {
          "command": "multimeter.connections.closeAll",
          "when": "view == multimeter.connections",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "multimeter.mmt.show.ui",
          "when": "activeCustomEditorId == mmt.editor",
          "group": "navigation"
        },
        {
          "command": "multimeter.mmt.show.yaml",
          "when": "activeCustomEditorId == mmt.editor",
          "group": "navigation"
        },
        {
          "command": "multimeter.mmt.show.full",
          "when": "activeCustomEditorId == mmt.editor",
          "group": "navigation"
        },
        {
          "command": "multimeter.mmt.show.as.text",
          "when": "activeCustomEditorId == mmt.editor",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "multimeter.mmt.show.as.text",
          "when": "resourceExtname == .mmt",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "multimeter.mmt.show.as.text",
          "when": "resourceExtname == .mmt"
        }
      ]
    }
  },
  "overrides": {
    "nth-check": "2.0.1",
    "postcss": "8.4.31",
    "webpack-dev-server": "5.3.0",
    "resolve-url-loader": "4.0.0",
    "glob": "^10.5.0",
    "js-yaml": "^4.1.1",
    "node-forge": "^1.3.2"
  },
  "keywords": [
    "test",
    "testing",
    "postman",
    "jmeter",
    "neoload",
    "smoke test",
    "performance test",
    "api test",
    "api testing",
    "api",
    "api testing tool",
    "api testing tools",
    "regression test",
    "regression testing",
    "regression",
    "regression test tool",
    "regression testing tool",
    "robot framework"
  ],
  "license": "BSL-1.0",
  "workspaces": [
    "core",
    "mmtview"
  ],
  "scripts": {
    "buildcore": "npm run build --prefix core",
    "buildview": "npm run build --prefix mmtview",
    "bootstrap": "sh -c 'if [ -f package-lock.json ]; then npm ci; else npm install; fi; npm audit || true'",
    "buildcli": "npm run buildcore && npm run pkg --prefix mmtcli",
    "pack": "vsce package",
    "pack-pre-release": "vsce package --pre-release",
    "publish": "vsce publish",
    "vscode:prepublish": "npm run build:vendor && npm run package",
    "compile": "npm run buildcore && npm run buildview && npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "build:vendor": "npm run build --prefix core && npm run build --prefix mmtview && rm -rf dist/core dist/mmtview && cp -R core/dist dist/core && cp -R mmtview/build dist/mmtview",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "jest",
    "website": "npm run dev --prefix website"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "20.x",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.95.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "ts-jest": "^29.4.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "axios": "^1.10.0",
    "buffer": "^6.0.3",
    "mmt-core": "file:./core/dist",
    "uuid": "^11.1.0",
    "ws": "^8.18.3",
    "xml-js": "^1.6.11",
    "yaml": "^2.8.0"
  }
}
