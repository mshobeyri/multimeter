{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Insiders + Proposed API)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--enable-proposed-api",
        "mshobeyri.multimeter",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "compile-webview"
    }
  ]
}
